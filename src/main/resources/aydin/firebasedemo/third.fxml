<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aydin.firebasedemo.ThirdController">
    <children>
        <VBox alignment="CENTER" prefHeight="373.0" prefWidth="530.0" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
            <Label text="CSC325-SW Engineering Student: check out the console window for the output messages..." />
                <TextField fx:id="emailTextField" promptText="email" />
                <TextField fx:id="phoneTextField" promptText="phone" />
                <TextField fx:id="nameTextField" promptText="name" />
                <TextField fx:id="passwordTextField" promptText="password" />
                <HBox alignment="TOP_CENTER" prefHeight="55.0" prefWidth="518.0" spacing="10.0">
                    <children>
                        <Button fx:id="registerButton" mnemonicParsing="false" onAction="#registerButtonClicked" prefHeight="30.0" prefWidth="80.0" text="Register" />
                        <Button fx:id="switchSecondaryViewButton" onAction="#switchToSecondary" prefHeight="30.0" prefWidth="180.0" text="Back To Home" />
                    </children>
                </HBox>
                <TextArea fx:id="outputTextArea" prefHeight="218.0" prefWidth="507.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
