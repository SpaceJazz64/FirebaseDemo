<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.PasswordField?>
<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aydin.firebasedemo.PrimaryController">
    <VBox alignment="CENTER" spacing="20.0">
        <children>
            <Label text="Login" />

            <TextField fx:id="emailTextField" promptText="Email" />
            <PasswordField fx:id="passwordTextField" promptText="Password" />

            <Button text="Sign In" onAction="#handleLogin" />
        </children>
    </VBox>
</AnchorPane>
